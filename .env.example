# Copy to .env and fill in the values. Do NOT commit .env.

# ---------- LLM provider ----------
# Options: "ollama" (default, local) or "openai"
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.3

# ---------- Ollama (local) ----------
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_API_KEY=ollama
LLM_MODEL=gemma3:4b

# ---------- OpenAI (optional) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Embedding model (runs locally via sentence-transformers) ----------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------- Chunking ----------
CHUNK_SIZE=400
CHUNK_OVERLAP=60

# ---------- Data ----------
# Absolute path to a folder that contains the domain subfolders listed in config.Settings.domain_map
DATA_DIR=/Users/kamila/Desktop/rag
